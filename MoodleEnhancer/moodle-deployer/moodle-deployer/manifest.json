{
  "manifest_version": 2,
  "name": "Moodle Course Deployer — ISEN",
  "version": "1.2.0",
  "description": "Déploie automatiquement un cours packagé (.zip) dans Moodle en un clic.",

  "icons": {
    "48":  "icons/icon-48.svg",
    "96":  "icons/icon-96.svg"
  },

  "browser_action": {
    "default_icon": "icons/icon-48.svg",
    "default_popup": "popup.html",
    "default_title": "Déployer un cours"
  },

  "content_scripts": [
    {
      "matches": [
        "*://*.isen-ouest.fr/moodle4/*",
        "*://localhost/*",
        "*://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "storage",
    "activeTab",
    "windows",
    "tabs",
    "*://*.isen-ouest.fr/moodle4/*",
    "*://localhost/*",
    "*://127.0.0.1/*"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "moodle-deployer@isen",
      "strict_min_version": "109.0"
    }
  },

  "data_collection_permissions": {
    "required": [],
    "optional": []
  }
}
